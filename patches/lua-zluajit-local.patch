From: ghostty-love patch
Subject: [PATCH] adapt zluajit to local LuaJIT tree and Windows cross-build

Hollow keeps LuaJIT under `third_party/luajit-upstream` so the build can use a
local sibling tree instead of a fetched tarball, matching the project's
patch-oriented third_party layout.

It also needs `LUAJIT_OS=LUAJIT_OS_WINDOWS` for Windows targets in the local
cross-build path so buildvm generates the correct PE object flow.

diff --git a/build.zig.zon b/build.zig.zon
index 158663a..be56450 100644
--- a/build.zig.zon
+++ b/build.zig.zon
@@ -15,10 +15,7 @@
     // Once all dependencies are fetched, `zig build` no longer requires
     // internet connectivity.
     .dependencies = .{
-        .luajit = .{
-            .url = "https://github.com/LuaJIT/LuaJIT/archive/45b771bb2c693a4cc7e34e79b7d30ab10bb7776a.tar.gz",
-            .hash = "N-V-__8AANjeQgAOwyP-3bngzTq1w7tx43-7JOMtrj-1tuFq",
-        },
+        .luajit = .{ .path = "../luajit-upstream" },
     },

     // Specifies the set of files and directories that are included in this package.
diff --git a/build/luajit.zig b/build/luajit.zig
index 63fc6d7..edbfdf4 100644
--- a/build/luajit.zig
+++ b/build/luajit.zig
@@ -133,10 +133,12 @@ pub fn configure(
             "-DLUAJIT_TARGET=LUAJIT_ARCH_arm64",
             "-DLJ_ARCH_HASFPU=1",
             "-DLJ_ABI_SOFTFP=0",
+            if (target.result.os.tag == .windows) "-DLUAJIT_OS=LUAJIT_OS_WINDOWS" else "",
         },
         .x86_64 => &.{
             if (lua52_compat) "-DLUAJIT_ENABLE_LUA52COMPAT=1" else "",
             "-DLUAJIT_TARGET=LUAJIT_ARCH_X64",
+            if (target.result.os.tag == .windows) "-DLUAJIT_OS=LUAJIT_OS_WINDOWS" else "",
         },
         else => &.{},
     };
