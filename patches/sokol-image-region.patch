+SOKOL_API_IMPL void sg_update_image_region(sg_image img_id, const sg_image_region* region) {
+    SOKOL_ASSERT(_sg.valid);
+    SOKOL_ASSERT(region && region->data.ptr);
+    _sg_image_t* img = _sg_lookup_image(img_id.id);
+    if (img && img->slot.state == SG_RESOURCESTATE_VALID) {
+        const bool shape_valid =
+            region->width > 0 && region->height > 0 &&
+            region->x >= 0 && region->y >= 0 &&
+            region->width <= img->cmn.width &&
+            region->height <= img->cmn.height &&
+            region->x <= img->cmn.width - region->width &&
+            region->y <= img->cmn.height - region->height &&
+            region->row_pitch > 0 &&
+            (region->row_pitch % 4) == 0 &&
+            region->row_pitch >= region->width * 4;
+        size_t required_size = 0;
+        bool data_size_valid = false;
+        if (shape_valid) {
+            const size_t row_pitch = (size_t)region->row_pitch;
+            const size_t final_row_size = (size_t)region->width * 4;
+            const size_t preceding_rows = (size_t)(region->height - 1);
+            if (preceding_rows <= (SIZE_MAX - final_row_size) / row_pitch) {
+                required_size = preceding_rows * row_pitch + final_row_size;
+                data_size_valid = region->data.size >= required_size;
+            }
+        }
+        const bool valid = shape_valid && data_size_valid &&
+            img->cmn.usage.region_update &&
+            img->cmn.type == SG_IMAGETYPE_2D &&
+            img->cmn.pixel_format == SG_PIXELFORMAT_RGBA8 &&
+            img->cmn.num_mipmaps == 1 &&
+            img->cmn.upd_frame_index != _sg.frame_index;
+        SOKOL_ASSERT(valid);
+        if (valid) {
+            _sg_update_image_region(img, region);
+            img->cmn.upd_frame_index = _sg.frame_index;
+        }
+    }
+}
